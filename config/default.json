{
  "harness": {
    "runtime_mode": "graph",
    "max_turns": 50,
    "timeout_seconds": 300,
    "retry_on_tool_failure": true,
    "max_retries": 3
  },
  "llm": {
    "default_model": "@cf/moonshotai/kimi-k2.5",
    "routing": {
      "simple": {
        "model": "@cf/zai-org/glm-4.7-flash",
        "provider": "workers-ai",
        "max_tokens": 2048
      },
      "moderate": {
        "model": "@cf/moonshotai/kimi-k2.5",
        "provider": "workers-ai",
        "max_tokens": 4096
      },
      "complex": {
        "model": "anthropic/claude-sonnet-4.6",
        "provider": "openrouter",
        "max_tokens": 8192
      },
      "tool_call": {
        "model": "@cf/moonshotai/kimi-k2.5",
        "provider": "workers-ai",
        "max_tokens": 4096
      }
    },
    "plans": {
      "free": {
        "_description": "Free — Gemma 4 26B MoE on Workers AI (edge) + self-hosted Dense 31B for complex. Zero cost.",
        "general": {
          "simple":    { "model": "@cf/google/gemma-4-26b-a4b-it", "provider": "workers-ai",        "max_tokens": 2048 },
          "moderate":  { "model": "@cf/google/gemma-4-26b-a4b-it", "provider": "workers-ai",        "max_tokens": 4096 },
          "complex":   { "model": "gemma-4-31b",                   "provider": "custom-gemma4-local","max_tokens": 8192 },
          "tool_call": { "model": "@cf/google/gemma-4-26b-a4b-it", "provider": "workers-ai",        "max_tokens": 4096 }
        },
        "multimodal": {
          "vision":    { "model": "@cf/google/gemma-4-26b-a4b-it", "provider": "workers-ai",        "max_tokens": 4096 }
        }
      },
      "basic": {
        "_description": "Budget — Workers AI edge-local open-source models, lowest cost",
        "general": {
          "simple":    { "model": "@cf/zai-org/glm-4.7-flash",   "provider": "workers-ai", "max_tokens": 2048 },
          "moderate":  { "model": "@cf/zai-org/glm-4.7-flash",   "provider": "workers-ai", "max_tokens": 4096 },
          "complex":   { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 },
          "tool_call": { "model": "@cf/zai-org/glm-4.7-flash",   "provider": "workers-ai", "max_tokens": 2048 }
        },
        "coding": {
          "planner":     { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 },
          "implementer": { "model": "@cf/zai-org/glm-4.7-flash",   "provider": "workers-ai", "max_tokens": 8192 },
          "reviewer":    { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 },
          "debugger":    { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 }
        },
        "research": {
          "search":     { "model": "@cf/zai-org/glm-4.7-flash",   "provider": "workers-ai", "max_tokens": 2048 },
          "analyze":    { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 },
          "synthesize": { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 }
        },
        "creative": {
          "write": { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 8192 },
          "image": { "model": "@cf/bfl/flux-2-klein-4b",      "provider": "workers-ai" },
          "voice": { "model": "@cf/deepgram/aura-2-en",       "provider": "workers-ai" }
        },
        "multimodal": {
          "vision": { "model": "@cf/moonshotai/kimi-k2.5",    "provider": "workers-ai", "max_tokens": 4096 },
          "stt":    { "model": "@cf/openai/whisper",           "provider": "workers-ai" }
        }
      },
      "standard": {
        "_description": "Production — Workers AI for speed, GPT/DeepSeek/Claude for quality",
        "general": {
          "simple":    { "model": "@cf/moonshotai/kimi-k2.5",         "provider": "workers-ai", "max_tokens": 4096 },
          "moderate":  { "model": "openai/gpt-5.4-mini",              "provider": "openrouter", "max_tokens": 8192 },
          "complex":   { "model": "openai/gpt-5.4",                   "provider": "openrouter", "max_tokens": 16384 },
          "tool_call": { "model": "@cf/moonshotai/kimi-k2.5",         "provider": "workers-ai", "max_tokens": 4096 }
        },
        "coding": {
          "planner":     { "model": "openai/gpt-5.4",                   "provider": "openrouter", "max_tokens": 16384 },
          "implementer": { "model": "deepseek/deepseek-v3.2",           "provider": "openrouter", "max_tokens": 16384 },
          "reviewer":    { "model": "anthropic/claude-sonnet-4.6",       "provider": "openrouter", "max_tokens": 8192 },
          "debugger":    { "model": "deepseek/deepseek-v3.2",           "provider": "openrouter", "max_tokens": 16384 }
        },
        "research": {
          "search":     { "model": "@cf/moonshotai/kimi-k2.5",         "provider": "workers-ai", "max_tokens": 4096 },
          "analyze":    { "model": "openai/gpt-5.4-mini",              "provider": "openrouter", "max_tokens": 16384 },
          "synthesize": { "model": "openai/gpt-5.4",                   "provider": "openrouter", "max_tokens": 16384 }
        },
        "creative": {
          "write": { "model": "anthropic/claude-sonnet-4.6",      "provider": "openrouter", "max_tokens": 8192 },
          "image": { "model": "google/gemini-3.1-flash-image-preview", "provider": "openrouter" },
          "voice": { "model": "@cf/deepgram/aura-2-en",           "provider": "workers-ai" }
        },
        "multimodal": {
          "vision": { "model": "openai/gpt-5.4",                  "provider": "openrouter", "max_tokens": 8192 },
          "stt":    { "model": "@cf/openai/whisper",               "provider": "workers-ai" }
        }
      },
      "premium": {
        "_description": "Max quality — best-of-breed per role across all providers",
        "general": {
          "simple":    { "model": "openai/gpt-5.4-mini",              "provider": "openrouter", "max_tokens": 8192 },
          "moderate":  { "model": "openai/gpt-5.4",                   "provider": "openrouter", "max_tokens": 16384 },
          "complex":   { "model": "openai/gpt-5.4-pro",               "provider": "openrouter", "max_tokens": 16384 },
          "tool_call": { "model": "openai/gpt-5.4",                   "provider": "openrouter", "max_tokens": 16384 }
        },
        "coding": {
          "planner":     { "model": "openai/gpt-5.4-pro",               "provider": "openrouter", "max_tokens": 16384 },
          "implementer": { "model": "anthropic/claude-sonnet-4.6",       "provider": "openrouter", "max_tokens": 16384 },
          "reviewer":    { "model": "anthropic/claude-opus-4.6",         "provider": "openrouter", "max_tokens": 16384 },
          "debugger":    { "model": "deepseek/deepseek-r1-0528",        "provider": "openrouter", "max_tokens": 16384 }
        },
        "research": {
          "search":     { "model": "google/gemini-3.1-flash-lite-preview", "provider": "openrouter", "max_tokens": 8192 },
          "analyze":    { "model": "openai/gpt-5.4-pro",                "provider": "openrouter", "max_tokens": 16384 },
          "synthesize": { "model": "anthropic/claude-opus-4.6",         "provider": "openrouter", "max_tokens": 16384 }
        },
        "creative": {
          "write": { "model": "anthropic/claude-opus-4.6",         "provider": "openrouter", "max_tokens": 16384 },
          "image": { "model": "google/gemini-3-pro-image-preview", "provider": "openrouter" },
          "voice": { "model": "@cf/deepgram/aura-2-en",           "provider": "workers-ai" }
        },
        "multimodal": {
          "vision": { "model": "google/gemini-3.1-pro-preview",    "provider": "openrouter", "max_tokens": 16384 },
          "stt":    { "model": "@cf/openai/whisper",               "provider": "workers-ai" }
        }
      }
    },
    "providers": {
      "openrouter": {
        "note": "All non-@cf models route through CF AI Gateway → OpenRouter (400+ models)",
        "models": [
          "anthropic/claude-opus-4.6",
          "anthropic/claude-sonnet-4.6",
          "anthropic/claude-haiku-4.5",
          "openai/gpt-5.4-pro",
          "openai/gpt-5.4",
          "openai/gpt-5.4-mini",
          "openai/gpt-5.4-nano",
          "google/gemini-3.1-pro-preview",
          "google/gemini-3.1-flash-lite-preview",
          "google/gemini-3.1-flash-image-preview",
          "google/gemini-3-pro-image-preview",
          "deepseek/deepseek-v3.2",
          "deepseek/deepseek-v3.2-speciale",
          "deepseek/deepseek-r1-0528",
          "meta-llama/llama-4-maverick",
          "meta-llama/llama-4-scout",
          "qwen/qwen3.5-397b-a17b",
          "qwen/qwen3.5-122b-a10b",
          "mistralai/mistral-large-2512"
        ]
      },
      "workers-ai": {
        "note": "Edge-local inference via CF Workers AI (low cost, sub-second latency)",
        "models": [
          "@cf/moonshotai/kimi-k2.5",
          "@cf/zai-org/glm-4.7-flash",
          "@cf/openai/gpt-oss-120b",
          "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
          "@cf/deepgram/aura-2-en",
          "@cf/openai/whisper",
          "@cf/bfl/flux-2-klein-4b",
          "@cf/baai/bge-base-en-v1.5"
        ]
      },
      "local": {
        "api_base": "http://localhost:11434/v1",
        "models": ["*"],
        "note": "Any OpenAI-compatible endpoint (Ollama, vLLM, llama.cpp). No data leaves your machine."
      }
    },
    "provider_config": {
      "workers-ai": {
        "type": "cloudflare",
        "binding": "AI"
      },
      "openrouter": {
        "type": "openai-compat",
        "base_url": "https://openrouter.ai/api/v1",
        "env_key": "OPENROUTER_API_KEY",
        "note": "Proxied through CF AI Gateway for logging, caching, rate limits"
      }
    },
    "fallback_chain": [
      "workers-ai",
      "openrouter"
    ]
  },
  "memory": {
    "working": {
      "max_items": 100
    },
    "episodic": {
      "max_episodes": 10000,
      "ttl_days": 90
    },
    "semantic": {
      "backend": "in_memory"
    },
    "procedural": {
      "max_procedures": 500
    }
  },
  "rag": {
    "chunk_size": 512,
    "chunk_overlap": 64,
    "top_k": 10,
    "rerank_top_n": 5,
    "hybrid_alpha": 0.7
  },
  "voice": {
    "stt_model": "whisper-1",
    "tts_model": "tts-1",
    "sample_rate": 16000,
    "vad_threshold": 0.5
  },
  "eval": {
    "trials_per_task": 5,
    "time_budget_seconds": 600,
    "primary_metric": "pass_rate"
  },
  "governance": {
    "require_confirmation_for_destructive": true,
    "budget_limit_usd": 10.0,
    "allowed_domains": []
  }
}

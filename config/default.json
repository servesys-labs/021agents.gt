{
  "harness": {
    "max_turns": 50,
    "timeout_seconds": 300,
    "retry_on_tool_failure": true,
    "max_retries": 3
  },
  "llm": {
    "default_model": "claude-sonnet-4-20250514",
    "routing": {
      "simple": {
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 1024
      },
      "moderate": {
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 4096
      },
      "complex": {
        "model": "claude-opus-4-20250514",
        "max_tokens": 8192
      }
    }
  },
  "memory": {
    "working": {
      "max_items": 100
    },
    "episodic": {
      "max_episodes": 10000,
      "ttl_days": 90
    },
    "semantic": {
      "backend": "in_memory"
    },
    "procedural": {
      "max_procedures": 500
    }
  },
  "rag": {
    "chunk_size": 512,
    "chunk_overlap": 64,
    "top_k": 10,
    "rerank_top_n": 5,
    "hybrid_alpha": 0.7
  },
  "voice": {
    "stt_model": "whisper-1",
    "tts_model": "tts-1",
    "sample_rate": 16000,
    "vad_threshold": 0.5
  },
  "eval": {
    "trials_per_task": 5,
    "time_budget_seconds": 600,
    "primary_metric": "pass_rate"
  },
  "governance": {
    "require_confirmation_for_destructive": true,
    "budget_limit_usd": 10.0,
    "allowed_domains": []
  }
}

    "providers": {
      "anthropic": {
        "api_base": "https://api.anthropic.com",
        "models": [
          "claude-opus-4-6-20250627",
          "claude-sonnet-4-6-20250627",
          "anthropic/claude-sonnet-4.6"
        ]
      },
      "openai": {
        "api_base": "https://api.openai.com",
        "models": [
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.4-nano"
        ]
      },
      "cloudflare": {
        "api_base": "https://api.cloudflare.com/client/v4/accounts/{account_id}/ai",
        "models": [
          "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
          "@hf/mistral/mistral-7b-instruct-v0.2"
        ]
      },
      "gmi": {
        "api_base": "https://api.gmi-serving.com/v1",
        "models": [
          "deepseek-ai/DeepSeek-R1",
          "meta-llama/Llama-3.3-70B-Instruct",
          "mistralai/Mistral-Large-2411"
        ],
        "note": "OpenAI-compatible API. Data stays on GMI Cloud's US-based NVIDIA GPUs. Set GMI_API_KEY."
      },
      "local": {
        "api_base": "http://localhost:11434/v1",
        "models": [
          "*"
        ],
        "note": "Any OpenAI-compatible endpoint (Ollama, vLLM, llama.cpp, TGI). No data leaves your machine."
      }
    },
    "provider_config": {
      "workers-ai": {
        "type": "cloudflare",
        "binding": "AI"
      },
      "openrouter": {
        "type": "openai-compat",
        "base_url": "https://openrouter.ai/api/v1",
        "env_key": "OPENROUTER_API_KEY"
      }
    },
    "fallback_chain": [
      "workers-ai",
      "openrouter"
    ]
  },
  "memory": {
    "working": {
      "max_items": 100
    },
    "episodic": {
      "max_episodes": 10000,
      "ttl_days": 90
    },
    "semantic": {
      "backend": "in_memory"
    },
    "procedural": {
      "max_procedures": 500
    }
  },
  "rag": {
    "chunk_size": 512,
    "chunk_overlap": 64,
    "top_k": 10,
    "rerank_top_n": 5,
    "hybrid_alpha": 0.7
  },
  "voice": {
    "stt_model": "whisper-1",
    "tts_model": "tts-1",
    "sample_rate": 16000,
    "vad_threshold": 0.5
  },
  "eval": {
    "trials_per_task": 5,
    "time_budget_seconds": 600,
    "primary_metric": "pass_rate"
  },
  "governance": {
    "require_confirmation_for_destructive": true,
    "budget_limit_usd": 10.0,
    "allowed_domains": []
  }
}

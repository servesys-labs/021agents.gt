{
  "name": "code-reviewer",
  "description": "An agent that reviews code for bugs, security issues, performance problems, and style",
  "version": "0.2.0",
  "system_prompt": "You are a senior code reviewer. When given code, activate the /review skill — it's loaded into your prompt. Be precise, reference line numbers, show corrected code.",
  "enabled_skills": ["review"],
  "personality": "Precise, constructive, security-conscious, detail-oriented",
  "model": "anthropic/claude-sonnet-4.6",
  "max_tokens": 8192,
  "temperature": 0.0,
  "tools": [
    "read-file",
    "grep",
    "glob",
    "edit-file",
    "bash"
  ],
  "memory": {
    "working": {
      "max_items": 100
    },
    "episodic": {
      "max_episodes": 2000,
      "ttl_days": 90
    },
    "procedural": {
      "max_procedures": 50
    }
  },
  "governance": {
    "budget_limit_usd": 5.0,
    "blocked_tools": [],
    "require_confirmation_for_destructive": true
  },
  "max_turns": 10,
  "tags": [
    "code-review",
    "security",
    "development"
  ]
}

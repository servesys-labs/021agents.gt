  "api_call:/api/v1/agents" -> "endpoint:GET /api/v1/agents";
  "api_call:/api/v1/agents" -> "endpoint:POST /api/v1/agents";
  "api_call:/api/v1/agents/{var}/chat?message={var}&session_id={var}" -> "endpoint:POST /api/v1/agents/{name}/chat";
  "api_call:/api/v1/agents/{var}/run" -> "endpoint:POST /api/v1/agents/{name}/run";
  "api_call:/api/v1/agents?limit={var}&offset={var}" -> "endpoint:GET /api/v1/agents";
  "api_call:/api/v1/agents?limit={var}&offset={var}" -> "endpoint:POST /api/v1/agents";
  "api_call:/api/v1/api-keys" -> "endpoint:GET /api/v1/api-keys";
  "api_call:/api/v1/api-keys" -> "endpoint:POST /api/v1/api-keys";
  "api_call:/api/v1/api-keys/{var}" -> "endpoint:DELETE /api/v1/api-keys/{key_id}";
  "api_call:/api/v1/api-keys/{var}/rotate" -> "endpoint:POST /api/v1/api-keys/{key_id}/rotate";
  "api_call:/api/v1/audit/export?since_days={var}&limit=10000" -> "endpoint:GET /api/v1/audit/export";
  "api_call:/api/v1/audit/log?limit=50&since_days={var}&action={var}" -> "endpoint:GET /api/v1/audit/log";
  "api_call:/api/v1/auth/clerk/exchange" -> "endpoint:POST /api/v1/auth/clerk/exchange";
  "api_call:/api/v1/billing/usage" -> "endpoint:GET /api/v1/billing/usage";
  "api_call:/api/v1/billing/usage/daily" -> "endpoint:GET /api/v1/billing/usage/daily";

// wrangler.jsonc — AgentOS Cloudflare Agents deployment (modernized)
{
  "name": "agentos",
  "account_id": "ae92d4bf7c6c448f442d084a2358dcd5",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // Durable Objects — AgentOS agents + MCP server
  "durable_objects": {
    "bindings": [
      {
        "name": "AGENTOS_AGENT",
        "class_name": "AgentOSAgent"
      },
      {
        "name": "AGENTOS_MCP",
        "class_name": "AgentOSMcpServer"
      },
      {
        "name": "SANDBOX",
        "class_name": "AgentSandbox"
      },
      {
        "name": "SESSION_COUNTER",
        "class_name": "SessionCounterDO"
      },
      {
        "name": "SIGNAL_COORDINATOR",
        "class_name": "SignalCoordinatorDO"
      }
    ]
  },

  // Durable Object migrations
  "migrations": [
    {
      "tag": "v2",
      "new_sqlite_classes": ["AgentSandbox"]
    },
    {
      "tag": "v3",
      "new_classes": ["SessionCounterDO"]
    },
    {
      "tag": "v4",
      "new_sqlite_classes": ["SignalCoordinatorDO"]
    }
  ],

  // Dynamic Workers — open beta, available to all paid Workers users
  // See: https://blog.cloudflare.com/dynamic-workers/
  "worker_loaders": [{ "binding": "LOADER" }],

  // Sandbox SDK (Containers) — Python/Bash execution environment
  // "basic" = 1/4 vCPU, 1 GiB RAM, 4 GB disk — sufficient for numpy/pandas/matplotlib workloads
  // "lite" (256 MiB) was OOMing on heavy data analysis; basic provides 4x headroom
  "containers": [
    {
      "class_name": "AgentSandbox",
      "image": "./sandbox.Dockerfile",
      "instance_type": "basic",
      "max_instances": 500,
      // Rolling deploy: 10% first, wait 5 min, then 100% — prevents killing active sandboxes
      "rollout_step_percentage": [10, 100],
      "rollout_active_grace_period": 300
    }
  ],

  // Queues — guaranteed delivery telemetry pipeline (DO → Queue → Supabase)
  "queues": {
    "producers": [
      { "binding": "TELEMETRY_QUEUE", "queue": "agentos-telemetry" },
      { "binding": "SIGNAL_QUEUE", "queue": "agentos-signals" }
    ],
    "consumers": [
      {
        "queue": "agentos-telemetry",
        "max_batch_size": 50,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "agentos-telemetry-dlq"
      },
      {
        "queue": "agentos-signals",
        "max_batch_size": 50,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "agentos-signals-dlq"
      }
    ]
  },

  "analytics_engine_datasets": [
    {
      "binding": "SIGNAL_ANALYTICS",
      "dataset": "agentos_signals"
    }
  ],

  // Hyperdrive — accelerated Supabase Postgres connection from edge.
  //
  // HYPERDRIVE_ADMIN bypasses RLS for the runtime worker (a trusted
  // backend processing events across tenants). In prototype mode it
  // shares the HYPERDRIVE connection string; in production it should
  // point at a Hyperdrive config whose role is granted BYPASSRLS so
  // admin access is auditable at the database level.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "775f7e11ce8c479993855531f728770a"
    },
    {
      "binding": "HYPERDRIVE_ADMIN",
      "id": "775f7e11ce8c479993855531f728770a"
    }
  ],

  // R2 — object storage for RAG docs, generated files, agent artifacts
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "agentos-storage"
    }
  ],

  // Browser Rendering — headless Puppeteer on Cloudflare edge
  "browser": {
    "binding": "BROWSER"
  },

  // Workers AI binding for LLM inference and embeddings
  "ai": {
    "binding": "AI"
  },

  // Vectorize for semantic memory / RAG (1024-dim Qwen3-Embedding)
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "agentos-knowledge-v2"
    }
  ],

  // Workflows — durable agent execution with step-at-a-time checkpointing
  "workflows": [
    {
      "name": "agent-run",
      "binding": "AGENT_RUN_WORKFLOW",
      "class_name": "AgentRunWorkflow"
    }
  ],

  // KV — workflow progress events (DO polls and pushes to client)
  "kv_namespaces": [
    {
      "binding": "AGENT_PROGRESS_KV",
      "id": "30da23c287ee4f4c93d1a1f08cdd48a0"
    }
  ],

  // ── Composable building blocks — service bindings to sibling workers ──
  // Zero-latency, same-thread calls. Each block deploys independently.
  "services": [
    { "binding": "CHANNELS", "service": "agentos-channels" },
    { "binding": "SIGNALS_WORKER", "service": "agentos-signals" },
    { "binding": "COMPUTE", "service": "agentos-compute" },
    { "binding": "MEMORY", "service": "agentos-memory" }
  ],

  // Email Routing — configured in CF Dashboard (Email Routing → catch-all → Worker "agentos")
  // Emails to agent-name@yourdomain.com → agent DO "agent-name"

  // Custom domain — runtime.oneshots.co
  "routes": [
    { "pattern": "runtime.oneshots.co/*", "zone_name": "oneshots.co" }
  ],

  // Environment variables (secrets set via `wrangler secret put`)
  "vars": {
    "DEFAULT_PLAN": "free",
    "DEFAULT_PROVIDER": "custom-gemma4-fast",
    "DEFAULT_MODEL": "gemma-4-26b-moe",
    "CONTROL_PLANE_URL": "https://api.oneshots.co/api/v1",
    "LOCAL_SEARCH_URL": "https://search.oneshots.co",
    "OCR_ENDPOINT_URL": "https://ocr.oneshots.co",
    "PDF_RENDER_URL": "https://pdf.oneshots.co",
    "EMBEDDING_URL": "https://embed.oneshots.co",
    "RERANKER_URL": "https://rerank.oneshots.co",
    "CF_EXEC_POOL_SIZE": "24",
    "CF_EXEC_LEASE_MS": "20000",
    "CF_EXEC_WAIT_MS": "5000"
  }
}

// wrangler.jsonc — AgentOS Control-Plane Worker
{
  "name": "agentos-control-plane",
  "account_id": "ae92d4bf7c6c448f442d084a2358dcd5",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "limits": { "cpu_ms": 300000 },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // Hyperdrive — accelerated Supabase Postgres connection from edge.
  //
  // Two bindings so withOrgDb (RLS-enforced) and withAdminDb (RLS bypass)
  // can point at different connection strings:
  //
  //   HYPERDRIVE       — the default binding used by withOrgDb. Connects
  //                      via a role subject to RLS. Every query runs
  //                      inside a transaction that sets app.current_org_id
  //                      so row-level policies enforce tenant isolation.
  //
  //   HYPERDRIVE_ADMIN — used by withAdminDb for legitimate cross-org
  //                      reads (admin dashboards, marketplace discovery,
  //                      webhook dispatch, auth bootstrap, background
  //                      workers iterating across tenants). In prototype
  //                      mode this points at the same Hyperdrive config
  //                      as HYPERDRIVE — the TypeScript brand is the
  //                      only audit boundary. In production, point this
  //                      at a Hyperdrive config whose connection string
  //                      uses a role granted BYPASSRLS so admin access
  //                      is auditable at the database level too.
  // Both bindings share the same Hyperdrive config since Railway uses a
  // single superuser role. Admin bypass RLS is handled at the TypeScript
  // level (withAdminDb skips set_config), not at the DB role level.
  // Sharing one config halves the idle connection overhead — one pool
  // instead of two, each capped at 60 by Hyperdrive's platform limit.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "6f8984ddd503489895a7c97e6970f634"
    },
    {
      "binding": "HYPERDRIVE_ADMIN",
      "id": "6f8984ddd503489895a7c97e6970f634"
    }
  ],

  // Workers AI binding for LLM inference (meta-agent, issue classifier, etc.)
  "ai": {
    "binding": "AI"
  },

  // R2 — eval datasets, agent artifacts, document storage
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "agentos-storage"
    }
  ],

  // Vectorize for RAG embeddings
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "agentos-knowledge-v2"
    }
  ],

  // Service Binding to runtime worker — zero-latency internal calls
  "services": [
    {
      "binding": "RUNTIME",
      "service": "agentos"
    }
  ],

  // Durable Objects — cross-isolate atomic counters
  "durable_objects": {
    "bindings": [
      { "name": "RATE_LIMITER", "class_name": "RateLimiterDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_classes": ["RateLimiterDO"] }
  ],

  // KV — shared with runtime worker for real-time agent progress events
  "kv_namespaces": [
    {
      "binding": "AGENT_PROGRESS_KV",
      "id": "30da23c287ee4f4c93d1a1f08cdd48a0"
    }
  ],

  // Queues — async job processing
  "queues": {
    "producers": [
      { "binding": "JOB_QUEUE", "queue": "agentos-jobs" }
    ],
    "consumers": [
      {
        "queue": "agentos-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3,
        "dead_letter_queue": "agentos-jobs-dlq"
      },
      {
        "queue": "agentos-jobs-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 0
      }
    ]
  },

  // Cron Triggers — scheduled agent runs + data retention
  "triggers": {
    "crons": [
      "*/1 * * * *"
    ]
  },

  // Custom domain — api.oneshots.co
  "routes": [
    { "pattern": "api.oneshots.co/*", "zone_name": "oneshots.co" }
  ],

  // Environment variables (secrets via `wrangler secret put`)
  "vars": {
    "RUNTIME_WORKER_URL": "https://runtime.oneshots.co"
  }
}

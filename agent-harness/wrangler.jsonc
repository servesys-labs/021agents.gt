{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-harness",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  // Custom domain route managed via CF API (not wrangler routes — causes worker name collision)
  // Note: ctx.facets works in production without "experimental" flag
  "compatibility_flags": ["nodejs_compat"],

  // Alias: shim for agents/experimental/forever (not exported from published agents package)
  // @cloudflare/think 0.1.2 imports withFibers from this path, but Agent class already
  // includes fiber support natively. The shim provides an identity passthrough.
  "alias": {
    "agents/experimental/forever": "./src/shims/agents-experimental-forever.ts"
  },

  // Workers AI binding
  "ai": { "binding": "AI" },

  // Browser Rendering API — Puppeteer-powered headless browser
  "browser": { "binding": "MYBROWSER" },

  // Dynamic Worker loading — used by AgentSupervisor for facet code
  "worker_loaders": [{ "binding": "LOADER" }],

  // SPA assets served via Cloudflare Pages or Workers static assets
  // Build UI first: cd ui && npm run build
  "assets": {
    "directory": "./ui/build",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*", "/.well-known/*", "/a2a", "/a/*", "/mcp", "/channels/*", "/webhook/*", "/sfu/*"]
  },

  // Durable Objects: ChatAgent (Think) + Sandbox + AgentSupervisor + ReminderAgent + McpElicitation
  "durable_objects": {
    "bindings": [
      { "class_name": "ChatAgent", "name": "ChatAgent" },
      { "class_name": "ResearchSpecialist", "name": "ResearchSpecialist" },
      { "class_name": "CodingSpecialist", "name": "CodingSpecialist" },
      { "class_name": "Sandbox", "name": "Sandbox" },
      { "class_name": "AgentSupervisor", "name": "AgentSupervisor" },
      { "class_name": "ReminderAgent", "name": "ReminderAgent" },
      { "class_name": "McpElicitationServer", "name": "McpElicitationServer" },
      { "class_name": "VoiceAgent", "name": "VoiceAgent" },
      { "class_name": "MemorySpecialist", "name": "MemorySpecialist" },
      { "class_name": "EvalJudge", "name": "EvalJudge" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["Sandbox"] },
    { "tag": "v3", "new_sqlite_classes": ["AgentSupervisor"] },
    { "tag": "v4", "new_sqlite_classes": ["ReminderAgent", "McpElicitationServer"] },
    { "tag": "v5", "new_sqlite_classes": ["ResearchSpecialist", "CodingSpecialist"] },
    { "tag": "v6", "new_sqlite_classes": ["VoiceAgent"] },
    { "tag": "v7", "new_sqlite_classes": ["MemorySpecialist", "EvalJudge"] }
  ],

  // Analytics Engine for observability telemetry
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "agent_harness_telemetry" }
  ],

  // Workflows — durable execution for long-running agent tasks
  // (deep research, eval runs, RAG indexing, multi-step pipelines)
  "workflows": [
    { "name": "agent-task-workflow", "binding": "TASK_WORKFLOW", "class_name": "TaskWorkflow" }
  ],

  // Cloudflare Container for Sandbox (code execution environment)
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 10
    }
  ],

  // Observability — built-in structured logging
  "observability": {
    "enabled": true
  },

  // R2 — workspace file spillover + RAG documents + conversation archives
  "r2_buckets": [
    { "binding": "STORAGE", "bucket_name": "agent-harness-storage" }
  ],

  // Vectorize — semantic memory (cross-session embeddings)
  // Kept for backwards compat; new code should use AI_SEARCH below.
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "agent-harness-memory" }
  ],

  // AI Search — managed hybrid semantic + keyword search primitive
  // Replaces custom Vectorize + FTS5 RAG. Agents create per-user/org instances at runtime.
  "ai_search_namespaces": [
    { "binding": "AI_SEARCH", "namespace": "agent-harness" }
  ],

  // Artifacts — Git-for-agents (BETA: wrangler config not yet supported, requires
  // dashboard enablement). Once GA, uncomment:
  // "artifacts": [{ "binding": "ARTIFACTS", "namespace": "agent-sessions" }]

  // Hyperdrive — PlanetScale Postgres (managed via CF integration)
  // Database: 021agents (us-east-5). Unified billing through Cloudflare.
  // Agent-harness writes: session records, billing, OTEL events
  // Gateway also connects to the same Postgres for admin queries
  "hyperdrive": [
    { "binding": "DB", "id": "fe47bb91b8994078b15537a0d023190d" }
  ],

  // Queues — async writes to Postgres (non-blocking, with DLQ)
  // Pattern: agent onChatResponse → TELEMETRY_QUEUE.send() → consumer → Hyperdrive → Postgres
  // Failed messages retry 5x with backoff, then go to DLQ for manual replay
  "queues": {
    "producers": [
      { "binding": "TELEMETRY_QUEUE", "queue": "harness-telemetry" }
    ],
    "consumers": [
      {
        "queue": "harness-telemetry",
        "max_batch_size": 25,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "harness-telemetry-dlq",
        "retry_delay": 10
      },
      {
        "queue": "harness-telemetry-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 10,
        "max_retries": 0
      }
    ]
  },

  // Access code for login protection — set via: wrangler secret put ACCESS_CODE
  // Optional API keys for outbound Workers — also set as secrets
  // Email Workers — outbound email via send_email binding
  "send_email": [
    { "name": "EMAIL" }
  ],

  "vars": {
  }
}

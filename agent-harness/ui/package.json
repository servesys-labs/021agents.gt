{
	"name": "ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"tokens:build": "node ../design-tokens/build-tokens.mjs",
		"dev": "npm run tokens:build && vite dev",
		"build": "npm run tokens:build && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "npm run tokens:build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"lucide-svelte": "^1.0.1",
		"mode-watcher": "^1.1.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@xyflow/svelte": "^1.5.2",
		"highlight.js": "^11.11.1",
		"rehype-highlight": "^7.0.2",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-rehype": "^11.1.2",
		"svelte-sonner": "^1.1.0"
	}
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-harness",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  // Workers AI binding
  "ai": { "binding": "AI" },

  // Vite-built React SPA served as static assets
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*"]
  },

  // Durable Objects: ChatAgent (chat) + Sandbox (code execution)
  "durable_objects": {
    "bindings": [
      { "class_name": "ChatAgent", "name": "ChatAgent" },
      { "class_name": "Sandbox", "name": "Sandbox" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChatAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["Sandbox"] }
  ],

  // Cloudflare Container for Sandbox (code execution environment)
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "lite",
      "max_instances": 3
    }
  ],

  // Observability — built-in structured logging
  "observability": {
    "enabled": true
  },

  // Access code for login protection — set via: wrangler secret put ACCESS_CODE
  "vars": {}
}

{
  "name": "store-knowledge",
  "description": "Store a piece of knowledge in the semantic memory for later retrieval",
  "input_schema": {
    "type": "object",
    "properties": {
      "key": {
        "type": "string",
        "description": "A short identifier for this knowledge"
      },
      "content": {
        "type": "string",
        "description": "The knowledge content to store"
      },
      "tags": {
        "type": "array",
        "description": "Optional tags for categorization"
      }
    },
    "required": ["key", "content"]
  }
}

{
  "name": "@agentos/cli",
  "version": "0.2.0",
  "description": "AgentOS CLI - Build, run, and deploy autonomous agents (Bun-optimized)",
  "type": "module",
  "bin": {
    "agentos": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "build:bun": "bun build src/cli.ts --outfile dist/cli.js --target node --minify",
    "build:bundle": "esbuild src/cli.ts --bundle --platform=node --target=node18 --outfile=dist/cli.js --minify --format=esm",
    "build:executable": "npm run build && pkg dist/cli.js -o dist/agentos",
    "test": "vitest run",
    "test:bun": "bun test",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0",
    "node-fetch": "^3.3.0",
    "open": "^10.0.0",
    "tar": "^7.0.0",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/tar": "^6.1.0",
    "@types/which": "^3.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.1.0",
  "keywords": [
    "agent",
    "ai",
    "cli",
    "agentos",
    "bun",
    "autonomous",
    "llm"
  ],
  "author": "AgentOS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos/agentos.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/agentos/agentos/issues"
  },
  "homepage": "https://agentos.dev"
}

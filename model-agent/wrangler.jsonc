// Model Agent — reference implementation using the FULL CF Agents SDK surface.
// Think + Sub-Agents + Voice + A2A + Structured Input + CodeMode + MCP + Observability
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "model-agent",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true, "head_sampling_rate": 1 },

  // SPA asset serving — worker handles /agents/*, /api/*, /.well-known/* first
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*", "/.well-known/*"]
  },

  // ── Durable Objects: main agent + specialists + push + MCP ──
  "durable_objects": {
    "bindings": [
      { "name": "ModelAgent", "class_name": "ModelAgent" },
      { "name": "ResearchSpecialist", "class_name": "ResearchSpecialist" },
      { "name": "CodingSpecialist", "class_name": "CodingSpecialist" },
      { "name": "ReminderAgent", "class_name": "ReminderAgent" },
      { "name": "McpElicitationServer", "class_name": "McpElicitationServer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ModelAgent", "ResearchSpecialist", "CodingSpecialist", "ReminderAgent", "McpElicitationServer"] }
  ],

  // ── Dynamic Workers (CodeMode + extensions) ──
  "worker_loaders": [{ "binding": "LOADER" }],

  // ── Workers AI (LLM + embeddings + STT + TTS) ──
  "ai": { "binding": "AI" },

  // ── Browser Rendering ──
  "browser": { "binding": "MYBROWSER" },

  // ── Analytics Engine (observability telemetry) ──
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "model_agent_telemetry" }
  ]
}

// Model Agent — reference implementation using all CF Agents SDK features.
// Follows canonical patterns from cloudflare/agents examples.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "model-agent",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true, "head_sampling_rate": 1 },

  // SPA asset serving — worker handles /agents/* and /api/* first
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*"]
  },

  // ── Durable Objects ──
  "durable_objects": {
    "bindings": [
      { "name": "ModelAgent", "class_name": "ModelAgent" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ModelAgent"] }
  ],

  // ── Dynamic Workers (CodeMode isolate execution) ──
  "worker_loaders": [{ "binding": "LOADER" }],

  // ── Workers AI ──
  "ai": { "binding": "AI" },

  // ── Browser Rendering ──
  "browser": { "binding": "MYBROWSER" }
}
